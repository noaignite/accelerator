{
  "name": "@noaignite/tailwind-typography",
  "version": "0.1.13",
  "private": false,
  "description": "TailwindCSS plugin to create responsive typography",
  "keywords": [
    "tailwindcss",
    "typography"
  ],
  "bugs": {
    "url": "https://github.com/noaignite/accelerator/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/noaignite/accelerator.git",
    "directory": "packages/tailwind-typography"
  },
  "author": "NoA Ignite",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --config-loader unrun && pnpm build:docs",
    "build:docs": "node ../../scripts/buildPackageDocs.ts",
    "dev": "tsdown --config-loader unrun --watch",
    "lint": "eslint .",
    "test:coverage": "vitest run --coverage",
    "test:types": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "dependencies": {
    "@noaignite/utils": "workspace:*"
  },
  "devDependencies": {
    "@noaignite/style-guide": "workspace:*",
    "tailwindcss": "^3.4.19"
  },
  "peerDependencies": {
    "tailwindcss": "^3.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
