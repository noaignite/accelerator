{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"ignore": [
			".next/",
			".turbo/",
			"dist/",
			"node_modules/",
			"target/",
			"compiled/",
			"public/",
			"storybook-static/",
			".env*",
			".env.provision.production",
			".env.provision.stage",
			"package-lock.json",
			"pnpm-lock.yaml",
			"yarn.lock",
			"next-env.d.ts"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "space",
		"lineWidth": 100,
		"indentWidth": 2
	},
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "asNeeded"
		}
	}
}
