{
  "name": "@noaignite/utils",
  "version": "3.7.1",
  "private": false,
  "description": "Utility functions used by NoA Ignite",
  "keywords": [
    "utils"
  ],
  "bugs": {
    "url": "https://github.com/noaignite/accelerator/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/noaignite/accelerator.git",
    "directory": "packages/utils"
  },
  "license": "MIT",
  "author": "NoA Ignite",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --config-loader unrun && pnpm build:docs",
    "build:docs": "node ../../scripts/buildPackageDocs.ts",
    "lint": "eslint .",
    "test:coverage": "vitest run --coverage",
    "test:types": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "dependencies": {
    "@noaignite/types": "workspace:*"
  },
  "devDependencies": {
    "@noaignite/style-guide": "workspace:*"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
