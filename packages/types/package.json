{
  "name": "@noaignite/types",
  "version": "2.0.0",
  "private": false,
  "description": "Type helpers by NoA Ignite",
  "keywords": [
    "helpers",
    "typescript"
  ],
  "bugs": {
    "url": "https://github.com/noaignite/accelerator/issues"
  },
  "repository": {
    "type": "git",
