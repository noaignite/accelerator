{
  "name": "@noaignite/react-utils",
  "version": "0.17.0",
  "private": false,
  "description": "React utils",
  "keywords": [
    "react",
    "react-utils",
    "tanstack-intent",
    "typescript"
  ],
  "bugs": {
    "url": "https://github.com/noaignite/accelerator/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/noaignite/accelerator.git",
    "directory": "packages/react-utils"
  },
  "license": "MIT",
  "author": "NoA Ignite",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsdown --config-loader unrun && pnpm build:docs",
    "build:docs": "node ../../scripts/buildPackageDocs.ts",
    "dev": "tsdown --config-loader unrun --watch",
    "intent:stale": "pnpm dlx @tanstack/intent@latest stale skills",
    "intent:validate": "pnpm dlx @tanstack/intent@latest validate skills",
    "lint": "eslint .",
    "test:coverage": "vitest run --coverage",
    "test:types": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "dependencies": {
    "@noaignite/types": "workspace:*",
    "@noaignite/utils": "workspace:*"
  },
  "devDependencies": {
    "@noaignite/style-guide": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "react": "^19.2.5"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
