{
  "name": "accelerator",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm packages:build && pnpm docs:build",
    "ci:release": "pnpm build && pnpm test && changeset publish",
    "ci:status": "changeset status --since=origin/main",
    "ci:test": "pnpm lint && pnpm test:types && pnpm test:coverage",
    "clean": "node ./scripts/clean.ts",
    "dev": "turbo dev",
    "docs:build": "pnpm --filter docs build",
    "docs:dev": "pnpm --filter docs dev",
    "docs:start": "pnpm --filter docs start",
    "format": "prettier --write .",
    "lint": "turbo lint",
    "packages:build": "turbo build --filter=@noaignite/*",
    "packages:build-docs": "turbo build:docs --filter=@noaignite/*",
    "pre-commit": "lint-staged",
    "prepare": "node .husky/install.mjs",
    "release:verdaccio": "pnpm build && pnpm test && pnpm publish --no-git-checks --recursive --registry=\"http://localhost:4873/\"",
    "test": "pnpm lint && pnpm test:types && pnpm test:unit",
    "test:coverage": "turbo test:coverage",
    "test:types": "turbo test:types",
    "test:unit": "turbo test:unit",
    "test:unit:watch": "turbo watch test:unit:watch"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@noaignite/style-guide": "workspace:*",
    "@types/node": "^24.12.4",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "ts-morph": "^27.0.2",
    "tsdown": "^0.22.1",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "unrun": "^0.3.0",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=24",
    "pnpm": "^11"
  }
}
