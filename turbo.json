{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "GITHUB_OUTPUT",
    "GITHUB_REPOSITORY",
    "NODE_ENV",
    "PUBLISHED_PACKAGES",
    "npm_config_user_agent"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "build:docs": {
      "dependsOn": ["^build:docs"],
      "outputs": ["dist/docs/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test:coverage": {
      "dependsOn": ["^test:coverage"]
    },
    "test:unit": {
      "dependsOn": ["^test:unit"]
    },
    "test:unit:watch": {
      "dependsOn": ["^test:unit:watch"]
    },
    "test:types": {
      "dependsOn": ["^test:types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
